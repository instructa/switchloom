# Local runtime and coordination state
(^|/)\.model-routing/
(^|/)\.planr/
(^|/)\.alchemy/
(^|/)\.wrangler/
(^|/)\.codex/
(^|/)\.claude/
(^|/)\.cursor/
(^|/)\.astro/
(^|/)\.cache/
(^|/)\.vite/
(^|/)\.turbo/
(^|/)\.nyc_output/
(^|/)(node_modules|target|dist|coverage|tmp)/
(^|/)npm/native/

# Generated reports stay local. The compact public byte certificate is the
# single deliberate tracked exception; raw workdirs and host logs are blocked.
(^|/)reports/(?!release-ready-v[0-9]+\.[0-9]+\.[0-9]+/public-byte-certification\.json$)

# Environment and credential files
(^|/)\.env$
(^|/)\.env\.
(^|/)\.envrc$
(^|/)\.dev\.vars$
(^|/)\.dev\.vars\.
(^|/)\.npmrc$
(^|/)\.netrc$
(^|/)\.git-credentials$
(^|/)\.aws/credentials$
(^|/)\.docker/config\.json$
(^|/)credentials\.json$
(^|/)secrets\.json$
(^|/)tokens\.json$
(^|/)service-account.*\.json$

# Private keys
\.pem$
\.key$
\.p12$
\.pfx$
\.jks$
\.keystore$
\.agekey$
(^|/)id_rsa$
(^|/)id_ed25519$
(^|/)id_ecdsa$
(^|/)id_dsa$

# Infrastructure state
\.tfstate($|\.)
\.tfplan$
\.tfvars$

# Local editor settings
(^|/)\.idea/
(^|/)\.vscode/settings\.json$
(^|/)\.vscode/launch\.json$

# Runtime transcripts, databases, and diagnostics
\.log$
\.jsonl$
\.(stdout|stderr|trace|pid)$
\.(sqlite|sqlite3|db)($|-)
\.(profraw|profdata)$
\.dSYM/
(\.tgz|\.crate)$
(^|/)core($|\.)
