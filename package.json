{
  "name": "switchloom",
  "version": "0.1.1",
  "description": "Deterministic model routing for coding agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/instructa/switchloom.git"
  },
  "homepage": "https://github.com/instructa/switchloom#readme",
  "bugs": "https://github.com/instructa/switchloom/issues",
  "type": "module",
  "bin": {
    "switchloom": "npm/bin/model-routing.js",
    "model-routing": "npm/bin/model-routing.js"
  },
  "files": [
    "npm/bin/model-routing.js",
    "npm/native",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "alchemy:check-runtime": "node scripts/check-alchemy-runtime.mjs",
    "catalog:regenerate": "node scripts/regenerate-preset-catalog.mjs",
    "deploy:test": "node scripts/cloudflare-test.mjs deploy",
    "distribution:test": "node --test npm/*.test.mjs && bash scripts/npm-pack-check.sh",
    "destroy:test": "node scripts/cloudflare-test.mjs destroy",
    "hooks:install": "git config core.hooksPath .githooks",
    "pack:check": "bash scripts/npm-pack-check.sh",
    "security:check": "bash scripts/secleak-check.sh",
    "site:build": "astro build && node scripts/build-site.mjs",
    "site:check": "pnpm site:test && astro check && pnpm site:build",
    "site:dev": "astro dev",
    "site:test": "vitest run && node --test website/alchemy-runtime.test.mjs website/cloudflare-launcher.test.mjs",
    "site:serve": "astro dev --host 127.0.0.1 --port 4173"
  },
  "devDependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/check": "^0.9.6",
    "@base-ui/react": "^1.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "alchemy": "0.93.12",
    "astro": "^7.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
